# Application
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# Database
DATABASE_URL=postgresql+asyncpg://erp_user:erp_pass@localhost:5432/erp_db

# PostgreSQL (for Docker)
POSTGRES_USER=erp_user
POSTGRES_PASSWORD=erp_pass
POSTGRES_DB=erp_db

# API Settings
API_V1_STR=/api/v1
PROJECT_NAME=FastAPI ERP Core
DEBUG=False
